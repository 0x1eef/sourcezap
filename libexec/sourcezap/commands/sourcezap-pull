#!/bin/sh
set -e

#
# globals
#
libexec="$(dirname "${0}")"/..
rad="${libexec}"/scripts/rad
repodir=$1

#
# functions
#
. "${libexec}"/functions/print.sh

#
# main
#
if [ ! -e "${repodir}"/.git ]; then
    printerr "repository should be cloned first"
    exit 1
fi

"${rad}" sync
printok "pull complete"
